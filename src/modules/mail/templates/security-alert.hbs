<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Security Alert</title>
  <style>
    body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 0; padding: 0; background-color: #f4f4f4; }
    .container { max-width: 600px; margin: 0 auto; background-color: #ffffff; }
    .header { background-color: #c53030; padding: 30px; text-align: center; }
    .header h1 { color: #ffffff; margin: 0; font-size: 28px; }
    .content { padding: 40px 30px; }
    .content h2 { color: #c53030; margin-top: 0; }
    .content p { color: #4a5568; line-height: 1.6; }
    .alert-box { background-color: #fff5f5; border: 1px solid #fc8181; border-radius: 8px; padding: 20px; margin: 20px 0; }
    .alert-title { color: #c53030; font-weight: bold; margin: 0 0 10px 0; font-size: 18px; }
    .alert-description { color: #742a2a; margin: 0; }
    .details-box { background-color: #f7fafc; border-radius: 8px; padding: 20px; margin: 20px 0; }
    .detail-row { padding: 8px 0; border-bottom: 1px solid #e2e8f0; }
    .detail-row:last-child { border-bottom: none; }
    .detail-label { color: #718096; font-size: 12px; text-transform: uppercase; }
    .detail-value { color: #2d3748; font-weight: 500; margin-top: 4px; }
    .action-box { background-color: #ebf8ff; border-radius: 8px; padding: 20px; margin: 20px 0; }
    .action-box p { margin: 0; color: #2c5282; }
    .button { display: inline-block; background-color: #c53030; color: #ffffff; padding: 14px 28px; text-decoration: none; border-radius: 6px; margin: 10px 5px; }
    .button.secondary { background-color: #4a5568; }
    .footer { background-color: #edf2f7; padding: 20px; text-align: center; font-size: 12px; color: #718096; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>⚠️ Security Alert</h1>
    </div>
    <div class="content">
      <h2>Security Notice</h2>
      <p>Hi {{firstName}},</p>

      <div class="alert-box">
        <p class="alert-title">{{alertType}}</p>
        <p class="alert-description">{{description}}</p>
      </div>

      <div class="details-box">
        <div class="detail-row">
          <p class="detail-label">Date & Time</p>
          <p class="detail-value">{{date}}</p>
        </div>
        {{#if ipAddress}}
        <div class="detail-row">
          <p class="detail-label">IP Address</p>
          <p class="detail-value">{{ipAddress}}</p>
        </div>
        {{/if}}
        {{#if device}}
        <div class="detail-row">
          <p class="detail-label">Device</p>
          <p class="detail-value">{{device}}</p>
        </div>
        {{/if}}
        {{#if location}}
        <div class="detail-row">
          <p class="detail-label">Location</p>
          <p class="detail-value">{{location}}</p>
        </div>
        {{/if}}
      </div>

      <div class="action-box">
        <p><strong>Was this you?</strong> If you recognize this activity, no action is needed. If you don't recognize this activity, please secure your account immediately.</p>
      </div>

      <p style="text-align: center;">
        <a href="#" class="button">Secure My Account</a>
        <a href="mailto:{{supportEmail}}" class="button secondary">Contact Support</a>
      </p>

      <p>Best regards,<br>The {{appName}} Security Team</p>
    </div>
    <div class="footer">
      <p>&copy; {{year}} {{appName}}. All rights reserved.</p>
      <p>This is an automated security notification.</p>
    </div>
  </div>
</body>
</html>
