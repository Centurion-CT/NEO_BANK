# =============================================================================
# BankApp Backend Environment Configuration
# =============================================================================
# SECURITY WARNING: Never commit .env files with real credentials to version control
# Copy this file to .env and fill in your actual values

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bankapp
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# -----------------------------------------------------------------------------
# Redis (Session & Cache)
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
# CRITICAL: Generate strong secrets for production
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your-access-token-secret-min-64-chars
JWT_REFRESH_SECRET=your-refresh-token-secret-min-64-chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# -----------------------------------------------------------------------------
# Encryption (AES-256-GCM for sensitive data)
# -----------------------------------------------------------------------------
# Use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your-32-byte-encryption-key-in-hex

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_FROM_NAME=BankApp
MAIL_FROM_EMAIL=noreply@bankapp.com
MAIL_IGNORE_TLS=false
MAIL_REQUIRE_TLS=false
MAIL_RATE_LIMIT=30

# -----------------------------------------------------------------------------
# Qoreid (KYC/Digital Identity Verification)
# -----------------------------------------------------------------------------
QOREID_BASE_URL=https://api.qoreid.com
QOREID_CLIENT_ID=your-qoreid-client-id
QOREID_CLIENT_SECRET=your-qoreid-client-secret
QOREID_SANDBOX=true

# -----------------------------------------------------------------------------
# Bunny CDN (Profile Picture Storage)
# -----------------------------------------------------------------------------
BUNNY_STORAGE_API_KEY=your-bunny-storage-api-key
BUNNY_STORAGE_ZONE=your-storage-zone-name
BUNNY_STORAGE_HOSTNAME=storage.bunnycdn.com
BUNNY_CDN_HOSTNAME=your-pullzone.b-cdn.net

# -----------------------------------------------------------------------------
# External Services (Placeholders)
# -----------------------------------------------------------------------------
# SMS_PROVIDER_API_KEY=
